# Application
PORT=3001
NODE_ENV=development

# Postgres (users-db)
USERS_DB_HOST=localhost
USERS_DB_PORT=5433
USERS_DB_USER=hmeet_users
USERS_DB_PASSWORD=hmeet_users_password
USERS_DB_NAME=hmeet_users

# Kafka
KAFKA_BROKERS=localhost:29092
KAFKA_GROUP_ID=users-service

# File uploads
UPLOAD_DEST=./uploads

# Keycloak
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=hmeet
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_ADMIN_CLIENT_ID=hmeet-backend
KEYCLOAK_CLIENT_SECRET=your-client-secret-here
