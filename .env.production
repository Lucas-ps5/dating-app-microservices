# Application
PORT=3000
NODE_ENV=production

# Keycloak Configuration
KEYCLOAK_AUTH_SERVER_URL=https://keycloak.yourdomain.com
KEYCLOAK_REALM=hmeet
KEYCLOAK_CLIENT_ID=hmeet-backend
KEYCLOAK_CLIENT_SECRET=your-production-client-secret

# JWT Configuration
JWT_ISSUER=https://keycloak.yourdomain.com/realms/hmeet
JWT_AUDIENCE=account

# CORS Configuration
CORS_ORIGIN=https://yourdomain.com